
@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="container mt-5">
    <h1 class="text-danger">Something went wrong</h1>
    <p class="text-muted">An unexpected error occurred while processing your request.</p>

    @if (Model.ShowRequestId)
    {
        <p class="small text-muted">
            <strong>Request ID:</strong> <code>@Model.RequestId</code>
        </p>
    }

    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary mt-3">Go Home</a>
</div>