

@model CreateMemberViewModel

<div class="container">
    <main role="main" class="pb-3">

        <header class="mb-4">
            <h3 class="text-primary-color">Add New Member</h3>
        </header>

        <form method="post" asp-action="Create" enctype="multipart/form-data">

            <div class="section-header mb-3">
                <h5 class="text-primary fw-bold">Personal Information</h5>
                <hr class="mt-2">
            </div>
            <div class="row g-3 mb-4">
                <div class="col-12 col-md-6">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" type="text" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="col-12 col-md-6">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="col-12 col-md-6">
                    <label asp-for="Phone" class="form-label"></label>
                    <input asp-for="Phone" class="form-control" />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>

                <div class="col-12 col-md-6">
                    <label asp-for="DateOfBirth" class="form-label"></label>
                    <input asp-for="DateOfBirth" class="form-control" type="date" />
                    <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                </div>

                <div class="col-12 col-md-6">
                    <label asp-for="Gender" class="form-label"></label>
                    <select asp-for="Gender" asp-items="Html.GetEnumSelectList<Gender>()" class="form-select">
                        <option value="">-- Select Gender --</option>
                    </select>
                    <span asp-validation-for="Gender" class="text-danger"></span>
                </div>

                <div class="col-12 col-md-6">
                    <label class="form-label">Member Photo</label>
                    <input type="file" name="PhotoFile" id="photoInput" class="form-control" accept="image/*" />
                    <img id="photoPreview" src="#" alt="Preview" class="mt-2 rounded-circle" style="display:none; width:60px; height:60px; object-fit:cover;" />
                </div>
            </div>

            <div class="section-header mb-3">
                <h5 class="text-primary fw-bold">Address Information</h5>
                <hr class="mt-2">
            </div>
            <div class="row g-3 mb-4">
                <div class="col-12 col-md-6">
                    <label asp-for="BuildingNumber" class="form-label"></label>
                    <input asp-for="BuildingNumber" class="form-control" />
                    <span asp-validation-for="BuildingNumber" class="text-danger"></span>
                </div>

                <div class="col-12 col-md-6">
                    <label asp-for="Street" class="form-label"></label>
                    <input asp-for="Street" class="form-control" />
                    <span asp-validation-for="Street" class="text-danger"></span>
                </div>

                <div class="col-12 col-md-6">
                    <label asp-for="City" class="form-label"></label>
                    <input asp-for="City" class="form-control" />
                    <span asp-validation-for="City" class="text-danger"></span>
                </div>
            </div>

            <div class="section-header mb-3">
                <h5 class="text-primary fw-bold">Health Data</h5>
                <hr class="mt-2">
            </div>
            <div class="row g-3 mb-4">
                <div class="col-12 col-md-6">
                    <label asp-for="HealthRecordViewModel.Height" class="form-label"></label>
                    <input asp-for="HealthRecordViewModel.Height" class="form-control" />
                    <span asp-validation-for="HealthRecordViewModel.Height" class="text-danger"></span>
                </div>

                <div class="col-12 col-md-6">
                    <label asp-for="HealthRecordViewModel.Weight" class="form-label"></label>
                    <input asp-for="HealthRecordViewModel.Weight" class="form-control" />
                    <span asp-validation-for="HealthRecordViewModel.Weight" class="text-danger"></span>
                </div>

                <div class="col-12 col-md-6">
                    <label asp-for="HealthRecordViewModel.BloodType" class="form-label"></label>
                    <select asp-for="HealthRecordViewModel.BloodType" class="form-select" asp-items="Html.GetEnumSelectList<BloodType>()">
                        <option value="">-- Select Blood Type --</option>
                    </select>
                    <span asp-validation-for="HealthRecordViewModel.BloodType" class="text-danger"></span>
                </div>

                <div class="col-12 col-md-6">
                    <label asp-for="HealthRecordViewModel.Note" class="form-label"></label>
                    <input asp-for="HealthRecordViewModel.Note" class="form-control" />
                    <span asp-validation-for="HealthRecordViewModel.Note" class="text-danger"></span>
                </div>
            </div>

            <footer class="d-flex justify-content-end gap-3 mt-4">
                <a asp-controller="Members" asp-action="Index" class="btn btn-outline-secondary px-4">
                    <i class="bi bi-arrow-left me-2"></i> Back to List
                </a>

                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-plus-circle me-2"></i> Add Member
                </button>
            </footer>

        </form>
    </main>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Preview photo before upload
        const photoInput = document.getElementById('photoInput');
        if(photoInput) {
            photoInput.addEventListener('change', function(e) {
                var file = e.target.files[0];
                if (file) {
                    var reader = new FileReader();
                    reader.onload = function(e) {
                        var preview = document.getElementById('photoPreview');
                        preview.src = e.target.result;
                        preview.style.display = 'block';
                    }
                    reader.readAsDataURL(file);
                }
            });
        }
    </script>
}