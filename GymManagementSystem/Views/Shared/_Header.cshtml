@{
   
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";

  
    string Active(string name) =>
        string.Equals(controller, name, StringComparison.OrdinalIgnoreCase) ? "active" : "";
}

<header>
    <nav class="navbar navbar-expand-lg bg-white my-3">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <img src="~/images/logo.jpg" alt="Power fitness" width="48" height="48" asp-append-version="true" />
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent"
                    aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarSupportedContent">
                <ul class="navbar-nav m-auto mb-2 mb-lg-0 mt-3 mt-lg-0">
                    <li class="nav-item">
                        <a class="nav-link px-3 py-2 mx-2 fw-bolder fs-5 @Active("Home")" aria-current="@(Active("Home") == "active" ? "page" : null)" asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link px-3 py-2 mx-2 fw-bolder fs-5 @Active("Members")" aria-current="@(Active("Members") == "active" ? "page" : null)" asp-controller="Members" asp-action="Index">Members</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link px-3 py-2 mx-2 fw-bolder fs-5 @Active("Trainers")" aria-current="@(Active("Trainers") == "active" ? "page" : null)" asp-controller="Trainer" asp-action="Index">Trainers</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link px-3 py-2 mx-2 fw-bolder fs-5 @Active("Sessions")" aria-current="@(Active("Sessions") == "active" ? "page" : null)" asp-controller="Session" asp-action="Index">Sessions</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link px-3 py-2 mx-2 fw-bolder fs-5 @Active("Plans")" aria-current="@(Active("Plans") == "active" ? "page" : null)" asp-controller="Plans" asp-action="Index">Plans</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link px-3 py-2 mx-2 fw-bolder fs-5 @Active("MemberShips")" aria-current="@(Active("MemberShips") == "active" ? "page" : null)" asp-controller="MemberShip" asp-action="Index">Memberships</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link px-3 py-2 mx-2 fw-bolder fs-5 @Active("Bookings")" aria-current="@(Active("Bookings") == "active" ? "page" : null)" asp-controller="Booking" asp-action="Index">Sessions Schedule</a>
                    </li>
                    <li class="nav-item">
                        <form asp-action="Logout" asp-controller="Account" method="post" class="d-inline">
                            <button type="submit" class="btn btn-link nav-link px-3 py-2 mx-2 fw-bolder fs-5 text-black-alternative">
                                Logout
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
</header>